# ======== PostgreSQL ========

APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_chat_demo
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_chat_demo
APP_SECRET_KEY=replace-with-a-long-random-secret


# ======== OpenAI Compatible API ========

OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_MODEL=deepseek-chat
OPENAI_MAX_TOKENS=2048
OPENAI_CONTEXT_MESSAGES=20
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2


# ======== RAG Knowledge Base ========

RAG_MAX_FILE_SIZE_MB=10
RAG_MAX_CHUNKS_PER_FILE=200
RAG_TOP_K=4
